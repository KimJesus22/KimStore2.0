---
import type { Producto } from '../store/cartStore';

interface Props {
  producto: Producto;
}

const { producto } = Astro.props;
---

<div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-lg transition-all duration-300 flex flex-col h-full group">
  <div class="h-48 bg-gray-50 relative border-b border-gray-100 flex items-center justify-center overflow-hidden">
    {producto.imageUrl ? (
      <img
        src={producto.imageUrl}
        alt={producto.nombre}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    ) : (
      <span class="text-6xl group-hover:scale-110 transition-transform duration-500">💻</span>
    )}

    <div class="absolute top-3 right-3">
      <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold uppercase tracking-wider ${producto.stock > 0 ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
        {producto.stock > 0 ? `${producto.stock} en stock` : 'Agotado'}
      </span>
    </div>
  </div>

  <div class="p-5 flex flex-col flex-grow">
    <h3 class="text-xl font-bold text-gray-900 leading-tight mb-2 line-clamp-1" title={producto.nombre}>
      {producto.nombre}
    </h3>

    <p class="text-sm text-gray-600 mb-4 flex-grow line-clamp-2">
      {producto.descripcion}
    </p>

    <div class="text-3xl font-black text-gray-900 mb-5">
      ${producto.precio.toLocaleString()}
    </div>

    <div class="space-y-3 mt-auto">
      <button
        class="btn-add-cart w-full bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white font-bold py-3 px-4 rounded-xl transition-colors flex justify-center items-center gap-2 shadow-sm disabled:opacity-50 disabled:cursor-not-allowed"
        data-producto={JSON.stringify(producto)}
        disabled={producto.stock === 0}
      >
        <span>{producto.stock > 0 ? 'Añadir al carrito' : 'Sin inventario'}</span>
        <span class="text-lg">🛒</span>
      </button>

      <button
        class="btn-ver-resenas w-full bg-gray-50 hover:bg-gray-100 text-gray-700 font-bold py-2.5 px-4 rounded-xl transition-colors flex justify-center items-center gap-2 border border-gray-200"
        data-id={producto.id}
        data-nombre={producto.nombre}
      >
        <span>⭐ Opiniones y Reseñas</span>
      </button>

      <div data-admin-actions class="flex justify-between items-center border-t border-gray-100 pt-3 hidden">
        <button
          class="btn-editar flex items-center gap-1 text-sm font-semibold text-gray-500 hover:text-blue-600 transition-colors px-2 py-1 rounded-md hover:bg-blue-50"
          data-id={producto.id}
        >
          ✏️ Editar
        </button>

        <button
          class="btn-eliminar flex items-center gap-1 text-sm font-semibold text-gray-500 hover:text-red-600 transition-colors px-2 py-1 rounded-md hover:bg-red-50"
          data-id={producto.id}
        >
          🗑️ Eliminar
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import { agregarAlCarrito } from '../store/cartStore';
  import type { Producto } from '../store/cartStore';
  import Swal from 'sweetalert2';

  interface Resena {
    id: number;
    username: string;
    calificacion: number;
    comentario: string;
    fecha: string;
  }

  const API_URL = ['localhost', '127.0.0.1'].includes(window.location.hostname)
    ? 'http://localhost:8080/api'
    : 'https://kimstore-api-backend.onrender.com/api';

  const escaparHtml = (valor: string | number) => {
    const elemento = document.createElement('span');
    elemento.textContent = String(valor);
    return elemento.innerHTML;
  };

  const MOCK_RESENAS: Resena[] = [
    {
      id: -1,
      username: 'MarianaTech',
      calificacion: 5,
      comentario: 'La computadora llegó impecable, rápida y lista para trabajar. El rendimiento en multitarea se siente muy sólido.',
      fecha: 'Demo'
    },
    {
      id: -2,
      username: 'SetupGamer',
      calificacion: 4,
      comentario: 'Muy buena relación precio-rendimiento. La compraría de nuevo para un setup de oficina o gaming casual.',
      fecha: 'Demo'
    }
  ];

  const userRole = localStorage.getItem('kimstore_role');
  if (userRole === 'ROLE_ADMIN') {
    const panelesAdmin = document.querySelectorAll('[data-admin-actions]');
    panelesAdmin.forEach(panel => panel.classList.remove('hidden'));
  }

  const botonesCarrito = document.querySelectorAll('.btn-add-cart');
  botonesCarrito.forEach(boton => {
    boton.addEventListener('click', () => {
      const productoStr = boton.getAttribute('data-producto');
      if (!productoStr) return;

      const producto = JSON.parse(productoStr) as Producto;
      agregarAlCarrito(producto);

      Swal.fire({
        toast: true,
        position: 'bottom-end',
        icon: 'success',
        title: 'Agregado al carrito',
        showConfirmButton: false,
        timer: 1500,
        background: '#1F2937',
        color: '#fff'
      });
    });
  });

  const botonesEliminar = document.querySelectorAll('.btn-eliminar');
  botonesEliminar.forEach(boton => {
    boton.addEventListener('click', async () => {
      const id = boton.getAttribute('data-id');
      const token = localStorage.getItem('kimstore_token');

      if (!token || !id) return;

      const confirmacion = await Swal.fire({
        title: '¿Estás seguro?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#EF4444',
        cancelButtonColor: '#6B7280',
        confirmButtonText: 'Sí, eliminar'
      });

      if (!confirmacion.isConfirmed) return;

      try {
        const response = await fetch(`${API_URL}/productos/${id}`, {
          method: 'DELETE',
          headers: {
            'Authorization': `Bearer ${token}`
          }
        });

        if (!response.ok) throw new Error('Error al eliminar');

        Swal.fire('Eliminado', 'El producto ha sido borrado.', 'success').then(() => {
          window.location.reload();
        });
      } catch (error: unknown) {
        Swal.fire(
          'Error',
          error instanceof Error ? error.message : 'No se pudo eliminar el producto',
          'error'
        );
      }
    });
  });

  const botonesResenas = document.querySelectorAll('.btn-ver-resenas');

  botonesResenas.forEach(boton => {
    boton.addEventListener('click', async () => {
      const id = boton.getAttribute('data-id');
      const nombre = boton.getAttribute('data-nombre') || 'este producto';

      if (!id) return;

      try {
        const response = await fetch(`${API_URL}/resenas/producto/${id}`);
        if (!response.ok) throw new Error('No se pudieron cargar las reseñas');

        const resenas: Resena[] = await response.json();
        let htmlResenas = '<div class="text-left space-y-3 max-h-72 overflow-y-auto p-1 mt-4">';

        const resenasVisibles = resenas.length > 0 ? resenas : MOCK_RESENAS;

        if (resenas.length === 0) {
          htmlResenas += `
            <div class="rounded-xl border border-blue-100 bg-blue-50 px-4 py-3 text-blue-800">
              <p class="text-sm font-bold">Reseñas de ejemplo</p>
              <p class="text-xs mt-1">Aún no hay reseñas reales para este producto. Estas tarjetas son mock para previsualizar el diseño.</p>
            </div>`;
        }

        resenasVisibles.forEach(resena => {
            const estrellas = '⭐'.repeat(resena.calificacion);
            const estrellasVacias = '☆'.repeat(5 - resena.calificacion);

            htmlResenas += `
              <div class="bg-white p-4 rounded-xl border border-gray-200 shadow-sm">
                <div class="flex justify-between items-center mb-2">
                  <span class="font-bold text-gray-800 flex items-center gap-2">👤 ${escaparHtml(resena.username)}</span>
                  <span class="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded-md">${escaparHtml(resena.fecha)}</span>
                </div>
                <div class="text-yellow-400 text-sm mb-2 tracking-widest">${estrellas}<span class="text-gray-300">${estrellasVacias}</span></div>
                <p class="text-sm text-gray-600 leading-relaxed">${escaparHtml(resena.comentario)}</p>
              </div>
            `;
          });

        htmlResenas += '</div>';

        const modalLista = await Swal.fire({
          title: `<span class="text-xl font-bold">Reseñas de ${escaparHtml(nombre)}</span>`,
          html: htmlResenas,
          showCancelButton: true,
          confirmButtonText: '✍️ Escribir Reseña',
          cancelButtonText: 'Cerrar',
          confirmButtonColor: '#3B82F6',
          cancelButtonColor: '#6B7280',
          width: '32em'
        });

        if (!modalLista.isConfirmed) return;

        const token = localStorage.getItem('kimstore_token');
        if (!token) {
          Swal.fire({
            icon: 'warning',
            title: 'Acceso Denegado',
            text: 'Debes iniciar sesión para dejar una reseña.'
          });
          return;
        }

        const formModal = await Swal.fire({
          title: 'Califica este producto',
          html: `
            <div class="space-y-4 text-left mt-4">
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-1">Estrellas</label>
                <select id="input-estrellas" class="w-full px-4 py-3 border border-gray-300 rounded-xl bg-gray-50 focus:ring-2 focus:ring-blue-500 focus:outline-none">
                  <option value="5">⭐⭐⭐⭐⭐ (5) ¡Excelente!</option>
                  <option value="4">⭐⭐⭐⭐ (4) Muy bueno</option>
                  <option value="3">⭐⭐⭐ (3) Bueno</option>
                  <option value="2">⭐⭐ (2) Regular</option>
                  <option value="1">⭐ (1) Malo</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-1">Comentario</label>
                <textarea id="input-comentario" rows="3" placeholder="¿Qué te pareció el producto?" class="w-full px-4 py-3 border border-gray-300 rounded-xl bg-gray-50 focus:ring-2 focus:ring-blue-500 focus:outline-none resize-none"></textarea>
              </div>
            </div>
          `,
          focusConfirm: false,
          showCancelButton: true,
          confirmButtonText: 'Publicar',
          cancelButtonText: 'Cancelar',
          confirmButtonColor: '#10B981',
          preConfirm: () => {
            const estrellas = (document.getElementById('input-estrellas') as HTMLSelectElement).value;
            const comentario = (document.getElementById('input-comentario') as HTMLTextAreaElement).value;

            if (!comentario.trim()) {
              Swal.showValidationMessage('Por favor escribe un comentario');
              return false;
            }

            return {
              calificacion: parseInt(estrellas),
              comentario
            };
          }
        });

        if (!formModal.value) return;

        const peticionPost = await fetch(`${API_URL}/resenas`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({
            productoId: Number(id),
            calificacion: formModal.value.calificacion,
            comentario: formModal.value.comentario
          })
        });

        if (!peticionPost.ok) {
          const errorData = await peticionPost.json();
          throw new Error(errorData.error || 'Error al publicar la reseña');
        }

        Swal.fire('¡Gracias!', 'Tu reseña ha sido publicada con éxito.', 'success');
      } catch (error: unknown) {
        Swal.fire(
          'Error',
          error instanceof Error ? error.message : 'No se pudo completar la acción',
          'error'
        );
      }
    });
  });
</script>
