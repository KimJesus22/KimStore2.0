<div class="p-0">
  <form id="formulario-producto" class="flex flex-col gap-4">
    <input
      type="text"
      id="nombre"
      placeholder="Nombre (ej. Laptop HP)"
      class="custom-input border border-white/10 rounded-xl p-3 bg-white/[0.03] text-white focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500/60 transition-all duration-300 placeholder-gray-600 shadow-inner"
      required
    />
    <input
      type="text"
      id="descripcion"
      placeholder="Descripción"
      class="custom-input border border-white/10 rounded-xl p-3 bg-white/[0.03] text-white focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500/60 transition-all duration-300 placeholder-gray-600 shadow-inner"
      required
    />
    <input
      type="number"
      id="precio"
      placeholder="Precio"
      step="0.01"
      class="custom-input border border-white/10 rounded-xl p-3 bg-white/[0.03] text-white focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500/60 transition-all duration-300 placeholder-gray-600 shadow-inner"
      required
    />
    <input
      type="number"
      id="stock"
      placeholder="Stock"
      class="custom-input border border-white/10 rounded-xl p-3 bg-white/[0.03] text-white focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500/60 transition-all duration-300 placeholder-gray-600 shadow-inner"
      required
    />

    <div>
      <label class="block text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Imagen (Opcional)</label>
      <input
        type="file"
        id="imagenInput"
        accept="image/*"
        class="w-full text-gray-400 px-3 py-2 border border-white/10 rounded-xl bg-white/[0.03] focus:outline-none focus:border-blue-500/60 transition-all duration-300 text-sm"
      />
    </div>

    <button
      type="submit"
      class="w-full bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 text-white font-bold py-3.5 px-4 rounded-xl transition-all duration-300 shadow-lg shadow-blue-500/20 active:scale-[0.98] cursor-pointer"
    >
      Guardar Producto
    </button>
  </form>
</div>

<script>
  import Swal from 'sweetalert2';

  const tokenInicial = localStorage.getItem('kimstore_token');

  if (!tokenInicial) {
    Swal.fire({
      icon: 'warning',
      title: 'Acceso Denegado',
      text: 'Debes iniciar sesión para ver esta página.',
      confirmButtonColor: '#3B82F6'
    }).then(() => {
      window.location.href = '/login';
    });
  }

  const formulario = document.getElementById('formulario-producto') as HTMLFormElement | null;
  const API_URL = ['localhost', '127.0.0.1'].includes(window.location.hostname)
    ? 'http://localhost:8080/api/productos'
    : 'https://kimstore-api-backend.onrender.com/api/productos';

  formulario?.addEventListener('submit', async (e: Event) => {
    e.preventDefault();

    const token = localStorage.getItem('kimstore_token');

    if (!token) {
      Swal.fire('Error', 'Tu sesión ha expirado', 'error');
      window.location.href = '/login';
      return;
    }

    // 1. Armamos el DTO de texto
    const productoDTO = {
      nombre: (document.getElementById('nombre') as HTMLInputElement).value,
      descripcion: (document.getElementById('descripcion') as HTMLInputElement).value,
      precio: parseFloat((document.getElementById('precio') as HTMLInputElement).value),
      stock: parseInt((document.getElementById('stock') as HTMLInputElement).value)
    };

    // 2. Creamos el paquete FormData
    const formData = new FormData();

    // TRUCO PRO: Metemos el JSON dentro de un "Blob" para que Spring Boot lo reconozca
    formData.append("producto", new Blob([JSON.stringify(productoDTO)], {
      type: "application/json"
    }));

    // 3. Atrapamos el archivo de imagen (si el usuario seleccionó uno)
    const imagenInput = document.getElementById('imagenInput') as HTMLInputElement;
    if (imagenInput.files && imagenInput.files.length > 0) {
      formData.append("imagen", imagenInput.files[0]);
    }

    try {
      // OJO: Al usar FormData, NO debes poner "Content-Type" en los headers,
      // el navegador lo calcula automáticamente.
      const respuesta = await fetch(API_URL, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${token}`
        },
        body: formData
      });

      // Si Spring Boot dice "OK" (Status 200)
      if (respuesta.ok) {
        Swal.fire({
          title: '¡Éxito!',
          text: 'El producto se guardó correctamente.',
          icon: 'success',
          confirmButtonColor: '#10b981' // emerald-500
        }).then(() => {
          window.location.reload();
        });
      }
      // Si Spring Boot detiene el paquete en la Aduana (Status 400 Bad Request)
      else if (respuesta.status === 400) {
        Swal.fire({
          title: 'Error de Validación',
          text: 'Revisa los datos. Asegúrate de no dejar campos vacíos y usar valores positivos.',
          icon: 'warning',
          confirmButtonColor: '#f59e0b' // amber-500
        });
      }
      // Si el servidor se apaga (Status 500)
      else {
        Swal.fire({
          title: 'Error',
          text: respuesta.status === 403
            ? 'No tienes permisos para realizar esta acción (Error 403).'
            : 'No pudimos comunicarnos con la base de datos.',
          icon: 'error',
          confirmButtonColor: '#ef4444' // red-500
        });
      }
    } catch (error: unknown) {
      console.error(error);
      Swal.fire({
        title: 'Error de Conexión',
        text: error instanceof Error ? error.message : 'Asegúrate de que Spring Boot esté encendido.',
        icon: 'error'
      });
    }
  });
</script>
