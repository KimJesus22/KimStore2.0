---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mis Compras | KimStore 2.0">
  <header class="bg-white border-b border-gray-200 sticky top-0 z-40">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <a href="/productos" class="flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors font-bold text-sm">
          ⬅️ Volver a la Tienda
        </a>
        <h1 class="font-black text-xl text-gray-900">Historial de <span class="text-blue-600">Pedidos</span></h1>
      </div>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-4 py-8">
    <div id="historial-contenedor" class="space-y-6">
      <div class="text-center py-12 text-gray-500 font-medium animate-pulse">
        Cargando tus recibos de compra...
      </div>
    </div>
  </main>
</Layout>

<script>
  interface ItemPedido {
    nombreProducto: string;
    cantidad: number;
    precioUnitario: number;
  }

  interface Pedido {
    id: number;
    fecha: string;
    total: number;
    items: ItemPedido[];
  }

  const token = localStorage.getItem('kimstore_token');
  const contenedor = document.getElementById('historial-contenedor');
  const PEDIDOS_API_URL = ['localhost', '127.0.0.1'].includes(window.location.hostname)
    ? 'http://localhost:8080/api/pedidos'
    : 'https://kimstore-api-backend.onrender.com/api/pedidos';

  if (!token) {
    window.location.href = '/login';
  }

  const escaparHtml = (valor: string | number) => {
    const elemento = document.createElement('span');
    elemento.textContent = String(valor);
    return elemento.innerHTML;
  };

  async function cargarHistorial() {
    try {
      const response = await fetch(`${PEDIDOS_API_URL}/mis-compras`, {
        method: 'GET',
        headers: {
          'Authorization': `Bearer ${token}`
        }
      });

      if (!response.ok) throw new Error('Error al descargar el historial');

      const pedidos: Pedido[] = await response.json();

      if (!contenedor) return;
      contenedor.innerHTML = '';

      if (pedidos.length === 0) {
        contenedor.innerHTML = `
          <div class="bg-white p-8 rounded-2xl border border-gray-200 text-center text-gray-500">
            <span class="text-4xl block mb-2">🛒</span>
            <p class="font-bold text-lg text-gray-800">Aún no has comprado nada</p>
            <p class="text-sm mt-1">Tus compras completadas aparecerán listadas aquí.</p>
          </div>
        `;
        return;
      }

      pedidos.forEach(pedido => {
        const tarjeta = document.createElement('div');
        tarjeta.className = 'bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden';

        let htmlContent = `
          <div class="bg-gray-50 p-4 border-b border-gray-200 flex justify-between items-center sm:px-6">
            <div>
              <p class="text-xs font-bold text-gray-400 uppercase">Pedido #${pedido.id}</p>
              <p class="text-sm font-semibold text-gray-600 mt-0.5">${escaparHtml(pedido.fecha)}</p>
            </div>
            <div class="text-right">
              <p class="text-xs font-bold text-gray-400 uppercase">Total Pagado</p>
              <p class="text-xl font-black text-green-600 mt-0.5">$${pedido.total.toLocaleString('es-MX', { minimumFractionDigits: 2 })}</p>
            </div>
          </div>
          <div class="p-4 sm:p-6 divide-y divide-gray-100">
        `;

        pedido.items.forEach(item => {
          htmlContent += `
            <div class="flex justify-between items-center py-3 first:pt-0 last:pb-0">
              <div>
                <p class="font-bold text-gray-800 text-base">${escaparHtml(item.nombreProducto)}</p>
                <p class="text-xs text-gray-500 mt-0.5">Cantidad: ${item.cantidad} x $${item.precioUnitario.toLocaleString('es-MX', { minimumFractionDigits: 2 })}</p>
              </div>
              <p class="font-bold text-gray-900">$${(item.cantidad * item.precioUnitario).toLocaleString('es-MX', { minimumFractionDigits: 2 })}</p>
            </div>
          `;
        });

        htmlContent += '</div>';
        tarjeta.innerHTML = htmlContent;
        contenedor.appendChild(tarjeta);
      });
    } catch {
      if (contenedor) {
        contenedor.innerHTML = '<div class="text-center text-red-500 font-bold p-4">Error al conectar con el servidor.</div>';
      }
    }
  }

  cargarHistorial();
</script>
