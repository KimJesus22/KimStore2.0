---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nueva Contraseña | KimStore 2.0">
  <main class="relative min-h-screen flex items-center justify-center bg-[#030712] px-4 overflow-hidden">
    <!-- Grid sutil de fondo -->
    <div class="grid-overlay"></div>

    <!-- Orbes Flotantes con Desenfoque (Aesthetics Premium) -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>

    <!-- Card de Reset Glassmorphism -->
    <div class="relative z-10 max-w-md w-full bg-white/[0.02] border border-white/[0.07] backdrop-blur-2xl p-8 sm:p-10 rounded-3xl shadow-2xl transition-all duration-500 hover:border-white/[0.12]">
      <div class="text-center mb-8">
        <!-- Logo Badge -->
        <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-blue-500/30 bg-blue-500/5 text-blue-400 text-xs font-bold uppercase tracking-wider mb-4 animate-pulse">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>
          Establecer Acceso
        </div>
        <h2 class="text-3xl font-extrabold text-white tracking-tight">Crea una Nueva Contraseña ✨</h2>
        <p class="mt-2 text-sm text-gray-400">
          Escribe tu nueva clave de acceso para restablecer tu cuenta.
        </p>
      </div>

      <form id="form-reset" class="space-y-5" onsubmit="event.preventDefault();">
        <div class="space-y-4">
          <div>
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Nueva Contraseña</label>
            <input
              id="input-password"
              type="password"
              required
              class="custom-input block w-full px-4 py-3 border border-white/10 rounded-xl bg-white/[0.03] text-white focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500/60 focus:bg-white/[0.06] transition-all duration-300 placeholder-gray-600 shadow-inner"
              placeholder="Escribe tu nueva contraseña"
            />
          </div>
          <div>
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Confirmar Contraseña</label>
            <input
              id="input-confirmar"
              type="password"
              required
              class="custom-input block w-full px-4 py-3 border border-white/10 rounded-xl bg-white/[0.03] text-white focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500/60 focus:bg-white/[0.06] transition-all duration-300 placeholder-gray-600 shadow-inner"
              placeholder="Confirma tu nueva contraseña"
            />
          </div>
        </div>

        <button
          type="submit"
          class="btn-gradient w-full flex justify-center items-center py-3.5 px-4 rounded-xl text-sm font-bold text-white bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 transition-all duration-300 shadow-lg shadow-blue-500/20 active:scale-[0.98] cursor-pointer"
        >
          Actualizar y Entrar
        </button>
      </form>
    </div>
  </main>
</Layout>

<style>
  /* ===== GRID DE FONDO ===== */
  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(circle at center, black, transparent 80%);
    pointer-events: none;
    z-index: 1;
  }

  /* ===== FLOATING ORBS ===== */
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.12;
    animation: floating 25s infinite ease-in-out alternate;
  }

  .orb-1 {
    width: 450px;
    height: 450px;
    background: rgba(59, 130, 246, 0.4);
    top: -10%;
    left: -5%;
    animation-duration: 20s;
  }

  .orb-2 {
    width: 500px;
    height: 500px;
    background: rgba(99, 102, 241, 0.4);
    bottom: -15%;
    right: -10%;
    animation-duration: 25s;
    animation-delay: -5s;
  }

  .orb-3 {
    width: 300px;
    height: 300px;
    background: rgba(168, 85, 247, 0.3);
    top: 40%;
    left: 45%;
    animation-duration: 30s;
    animation-delay: -10s;
  }

  @keyframes floating {
    0% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(40px, -40px) scale(1.1);
    }
    100% {
      transform: translate(-20px, 20px) scale(0.9);
    }
  }

  /* ===== TRANSICIONES INPUT ===== */
  .custom-input {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>

<script>
  import Swal from 'sweetalert2';

  const form = document.getElementById('form-reset');
  const API_URL = ['localhost', '127.0.0.1'].includes(window.location.hostname)
    ? 'http://localhost:8080/api/auth/reset-password'
    : 'https://kimstore-api-backend.onrender.com/api/auth/reset-password';

  form?.addEventListener('submit', async () => {
    const password = (document.getElementById('input-password') as HTMLInputElement).value;
    const confirmar = (document.getElementById('input-confirmar') as HTMLInputElement).value;
    
    // Extraemos el token de la URL sin tocar el frontmatter de Astro
    const urlParams = new URLSearchParams(window.location.search);
    const token = urlParams.get('token');

    if (!token) {
      Swal.fire({
        icon: 'error',
        title: 'Enlace Inválido',
        text: 'No se detectó un código de seguridad seguro.',
        background: '#1F2937',
        color: '#fff',
        confirmButtonColor: '#EF4444'
      });
      return;
    }

    if (password !== confirmar) {
      Swal.fire({
        icon: 'warning',
        title: 'Las contraseñas no coinciden',
        text: 'Por favor, escríbelas de manera idéntica.',
        background: '#1F2937',
        color: '#fff',
        confirmButtonColor: '#3B82F6'
      });
      return;
    }

    Swal.fire({
      title: 'Actualizando...',
      text: 'Registrando tu nueva clave de acceso seguro',
      allowOutsideClick: false,
      background: '#1F2937',
      color: '#fff',
      didOpen: () => Swal.showLoading()
    });

    try {
      const response = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: token, nuevaPassword: password })
      });

      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.error || 'El enlace caducó');
      }

      Swal.fire({
        icon: 'success',
        title: '¡Contraseña Actualizada!',
        text: 'Tu acceso ha sido restablecido con éxito.',
        confirmButtonColor: '#3B82F6',
        background: '#1F2937',
        color: '#fff'
      }).then(() => {
        window.location.href = '/login';
      });

    } catch (error: any) {
      Swal.fire({
        icon: 'error',
        title: 'Error',
        text: error.message || 'No se pudo restablecer la contraseña.',
        background: '#1F2937',
        color: '#fff',
        confirmButtonColor: '#EF4444'
      });
    }
  });
</script>
