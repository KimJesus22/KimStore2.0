---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bienvenido | KimStore 2.0">
  <style is:global>
    #cart-badge,
    .fixed.bottom-6.right-6 {
      display: none !important;
    }
  </style>

  <main class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-200 flex flex-col items-center justify-center px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-4xl mx-auto">
      <span class="inline-block py-1 px-4 rounded-full bg-blue-100 text-blue-700 text-sm font-bold mb-6 tracking-wide uppercase">
        KimStore 2.0
      </span>

      <h1 class="text-5xl md:text-7xl font-extrabold text-gray-900 tracking-tight mb-6">
        El Futuro de tu <br class="hidden sm:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600">
          Setup Tecnológico
        </span>
      </h1>

      <p class="text-lg md:text-xl text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed">
        Administra inventarios, descubre computadoras de alto rendimiento y gestiona tus compras con la plataforma más rápida y segura del mercado.
      </p>

      <div class="flex flex-col sm:flex-row gap-5 justify-center items-center">
        <a
          href="/register"
          class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white bg-blue-600 rounded-full shadow-lg hover:bg-blue-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
        >
          Únete Ahora
          <svg class="w-5 h-5 ml-2 -mr-1" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
          </svg>
        </a>

        <a
          href="/login"
          class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 text-base font-bold text-gray-800 bg-white border-2 border-gray-200 rounded-full shadow-sm hover:bg-gray-50 hover:border-gray-300 hover:-translate-y-1 transition-all duration-300"
        >
          Iniciar Sesión
        </a>
      </div>
    </div>

    <div class="absolute bottom-10 animate-bounce text-gray-400 hidden md:block">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </main>
</Layout>
