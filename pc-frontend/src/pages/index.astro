---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Bienvenido | KimStore 2.0">
  <style is:global>
    #cart-badge,
    .fixed.bottom-6.right-6 {
      display: none !important;
    }
  </style>

  <style>
    /* ===== ANIMATED GRADIENT MESH ===== */
    .hero-bg {
      position: relative;
      overflow: hidden;
      background: #030712;
    }

    .hero-bg::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          ellipse 80% 50% at 20% 40%,
          rgba(59, 130, 246, 0.15),
          transparent
        ),
        radial-gradient(
          ellipse 60% 40% at 80% 20%,
          rgba(99, 102, 241, 0.12),
          transparent
        ),
        radial-gradient(
          ellipse 50% 60% at 50% 80%,
          rgba(37, 99, 235, 0.08),
          transparent
        );
      animation: meshShift 12s ease-in-out infinite alternate;
    }

    @keyframes meshShift {
      0% {
        transform: scale(1) translate(0, 0);
      }
      50% {
        transform: scale(1.05) translate(-2%, 1%);
      }
      100% {
        transform: scale(1) translate(1%, -1%);
      }
    }

    /* ===== GRID OVERLAY ===== */
    .grid-overlay {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(
        ellipse 70% 50% at 50% 50%,
        black 20%,
        transparent 70%
      );
    }

    /* ===== FLOATING ORBS ===== */
    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.4;
      animation: orbFloat 8s ease-in-out infinite;
    }

    .orb-1 {
      width: 400px;
      height: 400px;
      background: rgba(59, 130, 246, 0.3);
      top: -10%;
      left: -5%;
      animation-duration: 10s;
    }

    .orb-2 {
      width: 300px;
      height: 300px;
      background: rgba(99, 102, 241, 0.25);
      bottom: -5%;
      right: -5%;
      animation-duration: 12s;
      animation-delay: -3s;
    }

    .orb-3 {
      width: 200px;
      height: 200px;
      background: rgba(139, 92, 246, 0.2);
      top: 40%;
      right: 20%;
      animation-duration: 9s;
      animation-delay: -5s;
    }

    @keyframes orbFloat {
      0%,
      100% {
        transform: translate(0, 0) scale(1);
      }
      33% {
        transform: translate(30px, -20px) scale(1.05);
      }
      66% {
        transform: translate(-20px, 15px) scale(0.95);
      }
    }

    /* ===== ENTRANCE ANIMATIONS ===== */
    .fade-up {
      opacity: 0;
      transform: translateY(30px);
      animation: fadeUp 0.8s ease-out forwards;
    }

    .fade-up-delay-1 {
      animation-delay: 0.15s;
    }
    .fade-up-delay-2 {
      animation-delay: 0.3s;
    }
    .fade-up-delay-3 {
      animation-delay: 0.45s;
    }
    .fade-up-delay-4 {
      animation-delay: 0.6s;
    }
    .fade-up-delay-5 {
      animation-delay: 0.75s;
    }

    @keyframes fadeUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* ===== GLOW LINE ===== */
    .glow-line {
      height: 1px;
      background: linear-gradient(
        90deg,
        transparent,
        rgba(59, 130, 246, 0.5),
        transparent
      );
      animation: glowPulse 3s ease-in-out infinite;
    }

    @keyframes glowPulse {
      0%,
      100% {
        opacity: 0.4;
      }
      50% {
        opacity: 1;
      }
    }

    /* ===== FEATURE CARDS ===== */
    .feature-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
      backdrop-filter: blur(12px);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .feature-card:hover {
      background: rgba(255, 255, 255, 0.06);
      border-color: rgba(59, 130, 246, 0.3);
      transform: translateY(-4px);
      box-shadow: 0 20px 40px -12px rgba(59, 130, 246, 0.15);
    }

    .feature-icon {
      background: linear-gradient(
        135deg,
        rgba(59, 130, 246, 0.15),
        rgba(99, 102, 241, 0.1)
      );
      border: 1px solid rgba(59, 130, 246, 0.2);
      transition: all 0.4s ease;
    }

    .feature-card:hover .feature-icon {
      background: linear-gradient(
        135deg,
        rgba(59, 130, 246, 0.25),
        rgba(99, 102, 241, 0.2)
      );
      border-color: rgba(59, 130, 246, 0.4);
      transform: scale(1.1);
    }

    /* ===== STAT CARD ===== */
    .stat-card {
      position: relative;
      overflow: hidden;
    }

    .stat-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, #3b82f6, transparent);
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .stat-card:hover::before {
      opacity: 1;
    }

    /* ===== CTA BUTTON ===== */
    .btn-primary {
      position: relative;
      overflow: hidden;
      background: linear-gradient(135deg, #2563eb, #4f46e5);
      transition: all 0.3s ease;
    }

    .btn-primary::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, #3b82f6, #6366f1);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .btn-primary:hover::before {
      opacity: 1;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px -8px rgba(59, 130, 246, 0.5);
    }

    .btn-primary span {
      position: relative;
      z-index: 1;
    }

    .btn-secondary {
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.04);
      backdrop-filter: blur(8px);
      transition: all 0.3s ease;
    }

    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.25);
      transform: translateY(-2px);
    }

    /* ===== SCROLL REVEAL ===== */
    .reveal {
      opacity: 0;
      transform: translateY(40px);
      transition: all 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ===== FLOATING PARTICLES ===== */
    .particle {
      position: absolute;
      width: 3px;
      height: 3px;
      background: rgba(59, 130, 246, 0.4);
      border-radius: 50%;
      animation: particleFloat linear infinite;
    }

    @keyframes particleFloat {
      0% {
        transform: translateY(0) scale(1);
        opacity: 0;
      }
      10% {
        opacity: 1;
      }
      90% {
        opacity: 1;
      }
      100% {
        transform: translateY(-100vh) scale(0.5);
        opacity: 0;
      }
    }

    /* ===== TECH MARQUEE ===== */
    .marquee-track {
      display: flex;
      animation: marqueeScroll 30s linear infinite;
      width: max-content;
    }

    @keyframes marqueeScroll {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(-50%);
      }
    }

    /* ===== NOISE TEXTURE ===== */
    .noise-overlay {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 9999;
      opacity: 0.015;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    }
  </style>

  <!-- Subtle noise texture overlay -->
  <div class="noise-overlay"></div>

  <!-- ========== HERO SECTION ========== -->
  <section class="hero-bg min-h-screen flex flex-col relative">
    <!-- Floating orbs -->
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="grid-overlay"></div>

    <!-- Floating particles -->
    <div
      class="particle"
      style="left: 10%; animation-duration: 12s; animation-delay: 0s;"
    >
    </div>
    <div
      class="particle"
      style="left: 25%; animation-duration: 15s; animation-delay: 2s;"
    >
    </div>
    <div
      class="particle"
      style="left: 45%; animation-duration: 10s; animation-delay: 4s;"
    >
    </div>
    <div
      class="particle"
      style="left: 65%; animation-duration: 14s; animation-delay: 1s;"
    >
    </div>
    <div
      class="particle"
      style="left: 80%; animation-duration: 11s; animation-delay: 3s;"
    >
    </div>
    <div
      class="particle"
      style="left: 90%; animation-duration: 13s; animation-delay: 5s;"
    >
    </div>
    <div
      class="particle"
      style="left: 35%; animation-duration: 16s; animation-delay: 6s;"
    >
    </div>
    <div
      class="particle"
      style="left: 55%; animation-duration: 9s; animation-delay: 7s;"
    >
    </div>

    <!-- Navbar -->
    <nav class="relative z-10 w-full px-6 sm:px-8 lg:px-12 py-5 fade-up">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <div class="flex items-center gap-2.5">
          <div
            class="w-9 h-9 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center"
          >
            <span class="text-white font-black text-sm">K</span>
          </div>
          <span class="text-white font-extrabold text-lg tracking-tight">
            KimStore <span class="text-blue-400 font-normal text-sm">2.0</span>
          </span>
        </div>

        <div class="flex items-center gap-3">
          <a
            href="/login"
            class="px-5 py-2 text-sm font-semibold text-gray-300 hover:text-white transition-colors"
          >
            Iniciar Sesión
          </a>
          <a
            href="/register"
            class="px-5 py-2.5 text-sm font-bold text-white bg-white/10 border border-white/10 rounded-full hover:bg-white/15 hover:border-white/20 transition-all"
          >
            Crear Cuenta
          </a>
        </div>
      </div>
    </nav>

    <!-- Hero Content -->
    <div
      class="relative z-10 flex-1 flex flex-col items-center justify-center px-6 sm:px-8 text-center -mt-10"
    >
      <div class="max-w-4xl mx-auto">
        <!-- Badge -->
        <div
          class="fade-up fade-up-delay-1 inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-blue-500/20 bg-blue-500/10 mb-8"
        >
          <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
          <span
            class="text-blue-300 text-xs font-bold tracking-widest uppercase"
            >Plataforma de Inventario Activa</span
          >
        </div>

        <!-- Headline -->
        <h1
          class="fade-up fade-up-delay-2 text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold text-white tracking-tight leading-[1.05] mb-6"
        >
          El futuro de tu
          <br />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-blue-500 to-indigo-400"
          >
            setup tecnológico
          </span>
        </h1>

        <!-- Subheadline -->
        <p
          class="fade-up fade-up-delay-3 text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed mb-10"
        >
          Gestiona inventarios en tiempo real, descubre hardware de alto
          rendimiento y controla cada operación desde un solo panel inteligente.
        </p>

        <!-- CTA Buttons -->
        <div
          class="fade-up fade-up-delay-4 flex flex-col sm:flex-row gap-4 justify-center items-center"
        >
          <a
            href="/register"
            class="btn-primary w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white rounded-full"
          >
            <span class="flex items-center gap-2">
              Comenzar Gratis
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </span>
          </a>

          <a
            href="/login"
            class="btn-secondary w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-gray-300 rounded-full"
          >
            Ya tengo cuenta
          </a>
        </div>

        <!-- Trust indicators -->
        <div
          class="fade-up fade-up-delay-5 mt-14 flex flex-wrap justify-center items-center gap-8 text-gray-500 text-sm"
        >
          <div class="flex items-center gap-2">
            <svg
              class="w-4 h-4 text-green-500"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"></path>
            </svg>
            <span>Sin tarjeta de crédito</span>
          </div>
          <div class="flex items-center gap-2">
            <svg
              class="w-4 h-4 text-green-500"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"></path>
            </svg>
            <span>Dashboard en tiempo real</span>
          </div>
          <div class="flex items-center gap-2">
            <svg
              class="w-4 h-4 text-green-500"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"></path>
            </svg>
            <span>Exportación a PDF</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="relative z-10 pb-10 flex justify-center">
      <div
        class="flex flex-col items-center gap-2 text-gray-600 animate-bounce"
      >
        <span class="text-xs font-medium tracking-wider uppercase"
          >Descubre más</span
        >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </div>
  </section>

  <!-- ========== TECH MARQUEE ========== -->
  <section class="bg-gray-950 border-y border-white/5 py-5 overflow-hidden">
    <div class="marquee-track">
      {
        [1, 2].map(() => (
          <div class="flex items-center gap-12 px-6">
            <span class="text-gray-600 text-sm font-semibold whitespace-nowrap tracking-wider">
              💻 LAPTOPS
            </span>
            <span class="text-gray-800">●</span>
            <span class="text-gray-600 text-sm font-semibold whitespace-nowrap tracking-wider">
              🖥️ DESKTOPS
            </span>
            <span class="text-gray-800">●</span>
            <span class="text-gray-600 text-sm font-semibold whitespace-nowrap tracking-wider">
              ⌨️ PERIFÉRICOS
            </span>
            <span class="text-gray-800">●</span>
            <span class="text-gray-600 text-sm font-semibold whitespace-nowrap tracking-wider">
              🎮 GAMING
            </span>
            <span class="text-gray-800">●</span>
            <span class="text-gray-600 text-sm font-semibold whitespace-nowrap tracking-wider">
              📊 INVENTARIO
            </span>
            <span class="text-gray-800">●</span>
            <span class="text-gray-600 text-sm font-semibold whitespace-nowrap tracking-wider">
              🔒 SEGURIDAD JWT
            </span>
            <span class="text-gray-800">●</span>
            <span class="text-gray-600 text-sm font-semibold whitespace-nowrap tracking-wider">
              📄 REPORTES PDF
            </span>
            <span class="text-gray-800">●</span>
            <span class="text-gray-600 text-sm font-semibold whitespace-nowrap tracking-wider">
              ☁️ CLOUDINARY
            </span>
            <span class="text-gray-800">●</span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ========== FEATURES SECTION ========== -->
  <section class="bg-gray-950 relative py-24 sm:py-32 px-6 sm:px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-16 reveal">
        <span
          class="inline-block text-blue-400 text-xs font-bold tracking-[0.2em] uppercase mb-4"
          >Características</span
        >
        <h2
          class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-5"
        >
          Todo lo que necesitas,<br class="hidden sm:block" />
          <span class="text-gray-500">en un solo lugar</span>
        </h2>
        <p class="text-gray-500 text-lg max-w-xl mx-auto">
          Desde el control de inventario hasta la generación de reportes
          financieros automatizados.
        </p>
      </div>

      <!-- Feature Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        <!-- Feature 1 -->
        <div class="feature-card rounded-2xl p-7 reveal">
          <div
            class="feature-icon w-12 h-12 rounded-xl flex items-center justify-center mb-5"
          >
            <span class="text-2xl">📦</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">
            Inventario Inteligente
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Control total de productos con alertas automáticas de stock crítico
            y métricas en tiempo real.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="feature-card rounded-2xl p-7 reveal">
          <div
            class="feature-icon w-12 h-12 rounded-xl flex items-center justify-center mb-5"
          >
            <span class="text-2xl">🔐</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Seguridad JWT</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Autenticación robusta con tokens JWT, roles de usuario y protección
            de endpoints sensibles.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="feature-card rounded-2xl p-7 reveal">
          <div
            class="feature-icon w-12 h-12 rounded-xl flex items-center justify-center mb-5"
          >
            <span class="text-2xl">📄</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Reportes PDF</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Exporta reportes de inventario profesionales con un solo clic,
            directamente desde el dashboard.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="feature-card rounded-2xl p-7 reveal">
          <div
            class="feature-icon w-12 h-12 rounded-xl flex items-center justify-center mb-5"
          >
            <span class="text-2xl">🛒</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Carrito de Compras</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Sistema de compras completo con carrito persistente, validación de
            stock y confirmaciones visuales.
          </p>
        </div>

        <!-- Feature 5 -->
        <div class="feature-card rounded-2xl p-7 reveal">
          <div
            class="feature-icon w-12 h-12 rounded-xl flex items-center justify-center mb-5"
          >
            <span class="text-2xl">⭐</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Sistema de Reseñas</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Los usuarios pueden calificar y comentar productos, generando
            confianza y retroalimentación valiosa.
          </p>
        </div>

        <!-- Feature 6 -->
        <div class="feature-card rounded-2xl p-7 reveal">
          <div
            class="feature-icon w-12 h-12 rounded-xl flex items-center justify-center mb-5"
          >
            <span class="text-2xl">☁️</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Imágenes en la Nube</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Subida de imágenes optimizada con Cloudinary. Sin almacenamiento
            local, máxima velocidad.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== STATS SECTION ========== -->
  <section class="bg-gray-950 border-t border-white/5 py-20 px-6 sm:px-8">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div
          class="stat-card text-center p-6 rounded-2xl bg-white/[0.03] border border-white/5 hover:border-white/10 transition-all reveal"
        >
          <p
            class="text-3xl sm:text-4xl font-black text-white mb-1"
            data-count="100"
          >
            0%
          </p>
          <p
            class="text-gray-500 text-xs font-semibold tracking-wider uppercase"
          >
            Java + Spring
          </p>
        </div>
        <div
          class="stat-card text-center p-6 rounded-2xl bg-white/[0.03] border border-white/5 hover:border-white/10 transition-all reveal"
        >
          <p
            class="text-3xl sm:text-4xl font-black text-white mb-1"
            data-count="24"
          >
            0/7
          </p>
          <p
            class="text-gray-500 text-xs font-semibold tracking-wider uppercase"
          >
            Disponibilidad
          </p>
        </div>
        <div
          class="stat-card text-center p-6 rounded-2xl bg-white/[0.03] border border-white/5 hover:border-white/10 transition-all reveal"
        >
          <p
            class="text-3xl sm:text-4xl font-black text-white mb-1"
            data-count="256"
          >
            &lt;1s
          </p>
          <p
            class="text-gray-500 text-xs font-semibold tracking-wider uppercase"
