---
import '../styles/global.css';
import type { Producto } from '../types/producto';
import ProductCard from '../components/ProductCard.astro';
import ProductForm from '../components/ProductForm.astro';

const API_URL = 'http://localhost:8080/api/productos';
let productos: Producto[] = [];
let backendDisponible = true;

try {
  const respuesta = await fetch(API_URL);

  if (!respuesta.ok) {
    throw new Error(`Error al consultar productos: ${respuesta.status}`);
  }

  productos = await respuesta.json();
} catch {
  backendDisponible = false;
}
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>KimStore - Dashboard Profesional</title>
  </head>
  <body class="bg-gray-50 font-sans p-8 max-w-6xl mx-auto">

    <header class="mb-12">
      <h1 class="text-4xl font-extrabold text-gray-900 mb-2">KimStore 2.0 💻</h1>
      <p class="text-gray-500">Gestión de inventario en tiempo real.</p>
    </header>

    <main class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <aside class="lg:col-span-1">
        <ProductForm />
      </aside>

      <section class="lg:col-span-2">
        {!backendDisponible && (
          <div class="rounded-xl border border-amber-200 bg-amber-50 p-5 text-amber-800 mb-6">
            <h2 class="font-bold text-lg mb-1">Backend no disponible</h2>
            <p class="text-sm">
              Levanta Spring Boot en <strong>http://localhost:8080</strong> para cargar, guardar, editar y eliminar productos.
            </p>
          </div>
        )}

        {backendDisponible && productos.length === 0 && (
          <div class="rounded-xl border border-gray-200 bg-white p-6 text-gray-500">
            No hay productos registrados todavía.
          </div>
        )}

        {productos.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {productos.map((p) => <ProductCard producto={p} />)}
          </div>
        )}
      </section>
    </main>

    <script>
      // Mantenemos los scripts aquí por ahora para que manejen los eventos de todos los componentes
      // (En el futuro los moveremos a archivos .ts separados para que sea 100% escalable)

      const botonesEditar = document.querySelectorAll('.btn-editar');
      const botonesEliminar = document.querySelectorAll('.btn-eliminar');
      const formulario = document.getElementById('formulario-producto') as HTMLFormElement;

      // Lógica de Editar
      botonesEditar.forEach(boton => {
        boton.addEventListener('click', async (e) => {
          const t = e.currentTarget as HTMLButtonElement;
          const id = t.getAttribute('data-id');
          const nombre = t.getAttribute('data-nombre');
          const precioActual = t.getAttribute('data-precio');

          const nuevoPrecioStr = prompt(`Nuevo precio para ${nombre}:`, precioActual || '');
          if (nuevoPrecioStr) {
            const nuevoPrecio = parseFloat(nuevoPrecioStr);
            await fetch(`http://localhost:8080/api/productos/${id}`, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                nombre: t.getAttribute('data-nombre'),
                descripcion: t.getAttribute('data-desc'),
                precio: nuevoPrecio,
                stock: parseInt(t.getAttribute('data-stock') || '0')
              })
            });
            window.location.reload();
          }
        });
      });

      // Lógica de Eliminar
      botonesEliminar.forEach(boton => {
        boton.addEventListener('click', async (e) => {
          const t = e.currentTarget as HTMLButtonElement;
          const id = t.getAttribute('data-id');
          if (confirm('¿Eliminar producto?')) {
            await fetch(`http://localhost:8080/api/productos/${id}`, { method: 'DELETE' });
            window.location.reload();
          }
        });
      });
    </script>
  </body>
</html>
