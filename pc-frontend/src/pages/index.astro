---
import '../styles/global.css';

// 1. CREAMOS EL MOLDE (Interfaz) DE TU PRODUCTO
interface Producto {
  id: number;
  nombre: string;
  descripcion: string;
  precio: number;
  stock: number;
}

const respuesta = await fetch('http://localhost:8080/api/productos');
const productos: Producto[] = await respuesta.json();
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>KimStore - Tu Tienda de PC</title>
  </head>
  <body class="bg-gray-50 font-sans p-8 max-w-5xl mx-auto">

    <h1 class="text-4xl font-extrabold text-gray-900 mb-2">Bienvenidos a KimStore 💻</h1>
    <p class="text-gray-500 mb-8">Catálogo disponible desde nuestra base de datos:</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {productos.map((producto) => (
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-lg transition-shadow duration-300">
          <h2 class="text-xl font-bold text-gray-800 mb-2">{producto.nombre}</h2>
          <p class="text-gray-600 text-sm mb-4">{producto.descripcion}</p>
          <p class="text-3xl font-black text-emerald-500 mb-2">${producto.precio}</p>
          <p class="text-xs text-gray-400 font-medium tracking-wide uppercase">Stock: {producto.stock} unidades</p>

          <div class="mt-4 flex gap-4 border-t border-gray-100 pt-4">

            <button class="text-sm text-blue-500 hover:text-blue-700 font-semibold flex items-center gap-1 btn-editar"
              data-id={producto.id}
              data-nombre={producto.nombre}
              data-desc={producto.descripcion}
              data-precio={producto.precio}
              data-stock={producto.stock}>
              ✏️ Editar Precio
            </button>

            <button class="text-sm text-red-500 hover:text-red-700 font-semibold flex items-center gap-1 btn-eliminar"
              data-id={producto.id}>
              🗑️ Eliminar
            </button>

          </div>
        </div>
      ))}
    </div>

    <hr class="my-12 border-gray-200" />

    <h2 class="text-2xl font-bold text-gray-800 mb-6">Añadir un Nuevo Producto ➕</h2>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 max-w-md">
      <form id="formulario-producto" class="flex flex-col gap-4">
        <input type="text" id="nombre" placeholder="Nombre (ej. Laptop HP)" class="border border-gray-300 rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-emerald-500" required />
        <input type="text" id="descripcion" placeholder="Descripción" class="border border-gray-300 rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-emerald-500" required />
        <input type="number" id="precio" placeholder="Precio (ej. 15000)" step="0.01" class="border border-gray-300 rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-emerald-500" required />
        <input type="number" id="stock" placeholder="Cantidad en inventario" class="border border-gray-300 rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-emerald-500" required />

        <button type="submit" class="bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-3 rounded-lg transition-colors mt-2">
          Guardar Producto
        </button>
      </form>
    </div>

    <script>
      interface NuevoProducto {
        nombre: string;
        descripcion: string;
        precio: number;
        stock: number;
      }

      // ==========================================
      // 1. LÓGICA PARA EDITAR PRECIO (PUT)
      // ==========================================
      const botonesEditar = document.querySelectorAll('.btn-editar');

      botonesEditar.forEach(boton => {
        boton.addEventListener('click', async (evento) => {
          const target = evento.currentTarget as HTMLButtonElement;

          const id = target.getAttribute('data-id');
          const nombre = target.getAttribute('data-nombre');
          const desc = target.getAttribute('data-desc');
          const precioActual = target.getAttribute('data-precio');
          const stock = target.getAttribute('data-stock');

          const nuevoPrecioStr = prompt(`Ingresa el NUEVO PRECIO para: ${nombre}`, precioActual || '');

          if (nuevoPrecioStr !== null && nuevoPrecioStr.trim() !== '') {
            const nuevoPrecio = parseFloat(nuevoPrecioStr);

            if (!isNaN(nuevoPrecio)) {
              const productoActualizado: NuevoProducto = {
                nombre: nombre || '',
                descripcion: desc || '',
                precio: nuevoPrecio,
                stock: parseInt(stock || '0')
              };

              try {
                const respuesta = await fetch(`http://localhost:8080/api/productos/${id}`, {
                  method: 'PUT',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(productoActualizado)
                });

                if (respuesta.ok) {
                  window.location.reload();
                } else {
                  alert('Hubo un problema al actualizar el precio.');
                }
              } catch (error) {
                console.error("Error al actualizar:", error);
              }
            } else {
              alert('Por favor, ingresa un número válido (ej. 15000.50).');
            }
          }
        });
      });

      // ==========================================
      // 2. LÓGICA PARA ELIMINAR (DELETE)
      // ==========================================
      const botonesEliminar = document.querySelectorAll('.btn-eliminar');

      botonesEliminar.forEach(boton => {
        boton.addEventListener('click', async (evento) => {
          const target = evento.currentTarget as HTMLButtonElement;
          const idProducto = target.getAttribute('data-id');

          if (confirm('¿Estás totalmente seguro de borrar este producto?')) {
            try {
              const respuesta = await fetch(`http://localhost:8080/api/productos/${idProducto}`, {
                method: 'DELETE'
              });

              if (respuesta.ok) {
                window.location.reload();
              }
            } catch (error) {
              console.error("Error al intentar borrar:", error);
            }
          }
        });
      });

      // ==========================================
      // 3. LÓGICA PARA GUARDAR (POST)
      // ==========================================
      const formulario = document.getElementById('formulario-producto') as HTMLFormElement;

      formulario.addEventListener('submit', async (evento) => {
        evento.preventDefault();

        const nuevoProducto: NuevoProducto = {
          nombre: (document.getElementById('nombre') as HTMLInputElement).value,
          descripcion: (document.getElementById('descripcion') as HTMLInputElement).value,
          precio: parseFloat((document.getElementById('precio') as HTMLInputElement).value),
          stock: parseInt((document.getElementById('stock') as HTMLInputElement).value)
        };

        try {
          const respuesta = await fetch('http://localhost:8080/api/productos', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(nuevoProducto)
          });

          if (respuesta.ok) {
            window.location.reload();
          } else {
            alert('Hubo un error al guardar.');
          }
        } catch (error) {
          console.error("Error conectando con Spring Boot:", error);
        }
      });
    </script>
  </body>
</html>